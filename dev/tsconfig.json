{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./tests",
    "declaration": false,
    "resolveJsonModule": true,
    "types": ["@playwright/test"]
  },
  "include": ["tests/**/*"],
  "exclude": ["node_modules"]
}
